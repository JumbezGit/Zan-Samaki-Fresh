# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# C extensions
*.egg-info/
dist/
build/
eggs/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Django
*.log
db.sqlite3
media/
staticfiles/

# Virtualenv
venv/
env/
ENV/

# Environment variables
.env
.env.local
.env.*.local

# Node/Vite
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vite
.cache/

